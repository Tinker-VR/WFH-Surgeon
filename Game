function drawORScene() {
    const M = MONITOR;
    ctx.save();
    ctx.beginPath(); ctx.roundRectPolyfill(M.sx, M.sy, M.sw, M.orH, 4); ctx.clip();

    const orBot = M.sy + M.orH;
    drawRect(M.sx, M.sy, M.sw, M.orH, COLORS.orWall);
    drawRect(M.sx, orBot - 60, M.sw, 60, COLORS.orFloor);
    ctx.strokeStyle = '#A0CFC5'; ctx.lineWidth = 1;
    for (let i = M.sx; i < M.sx+M.sw; i += 80) { ctx.beginPath(); ctx.moveTo(i, orBot-60); ctx.lineTo(i-30, orBot); ctx.stroke(); }

    // Lamp
    const lx = M.sx + M.sw/2;
    drawRoundRect(lx-18, M.sy-5, 36, 35, 10, '#90A4AE', '#546E7A', 2);
    ctx.fillStyle = '#ECEFF1'; ctx.strokeStyle = '#78909C'; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.arc(lx, M.sy+22, 70, Math.PI, 0); ctx.fill(); ctx.stroke();
    let lg = ctx.createLinearGradient(lx, M.sy+22, lx, orBot);
    lg.addColorStop(0, 'rgba(255,255,255,0.15)'); lg.addColorStop(1, 'rgba(255,255,255,0)');
    ctx.fillStyle = lg;
    ctx.beginPath(); ctx.moveTo(lx-65, M.sy+22); ctx.lineTo(lx+65, M.sy+22); ctx.lineTo(lx+150, orBot); ctx.lineTo(lx-150, orBot); ctx.fill();

    // Heart monitor
    const hmx = M.sx+25, hmy = M.sy+15;
    drawShadowRoundRect(hmx, hmy, 85, 65, 10, '#37474F', '#263238', 2);
    drawRoundRect(hmx+6, hmy+6, 73, 35, 5, '#000');
    ctx.strokeStyle = '#00E676'; ctx.lineWidth = 2;
    let ekg = (performance.now()/12) % 73;
    ctx.beginPath();
    ctx.moveTo(hmx+6, hmy+24); ctx.lineTo(hmx+6+ekg/2, hmy+24);
    ctx.lineTo(hmx+6+ekg/2+5, hmy+12); ctx.lineTo(hmx+6+ekg/2+10, hmy+34);
    ctx.lineTo(hmx+6+ekg/2+15, hmy+24); ctx.lineTo(hmx+79, hmy+24);
    ctx.stroke();
    ctx.fillStyle = (Math.floor(performance.now()/300)%2===0) ? '#00E676' : '#1B5E20';
    ctx.beginPath(); ctx.arc(hmx+68, hmy+52, 5, 0, Math.PI*2); ctx.fill();

    // Patient
    drawPatient(lx, orBot - 30);

    // Blood
    ctx.fillStyle = 'rgba(211,47,47,0.8)';
    GAME.bloodSpills.forEach(s => { ctx.beginPath(); ctx.arc(lx+s.x*0.8, orBot-30+s.y, s.r*0.8, 0, Math.PI*2); ctx.fill(); });

    // Arms
    let speed = GAME.state==='PLAYING' ? 400 : 2000;
    let sway = Math.sin(performance.now()/speed)*15 + Math.sin(performance.now()/(speed*0.5))*GAME.armReach*0.7;
    let sway2 = Math.cos(performance.now()/(speed*0.8))*(12+GAME.armReach*0.6);
    let erratic = GAME.armGlitchTimer > 0;

    if (erratic) {
        ctx.globalAlpha = 0.15;
        drawArm(M.sx+80, M.sy-10, lx-100+sway*1.5, orBot-35, true, true);
        drawArm(M.sx+M.sw-80, M.sy-10, lx+100-sway*1.5, orBot-35, true, false);
        ctx.globalAlpha = 1;
    }
    drawArm(M.sx+80, M.sy-10, lx-100+sway, orBot-35, erratic, true);
    drawArm(M.sx+180, M.sy-10, lx-50+sway2, orBot-40, erratic, true);
    drawArm(M.sx+M.sw-180, M.sy-10, lx+50-sway2, orBot-40, erratic, false);
    drawArm(M.sx+M.sw-80, M.sy-10, lx+100-sway, orBot-35, erratic, false);

    // HUD
    if (GAME.state === 'PLAYING' || GAME.state === 'RESOLUTION') {
        drawRoundRect(M.sx+12, M.sy+6, M.sw-24, 44, 12, 'rgba(0,0,0,0.65)', null);
        let hx = M.sx+28;
        for (let i = 0; i < GAME.maxHearts; i++) { drawText('❤', hx, M.sy+28, 32, i < GAME.hearts ? COLORS.red : '#444', 'left'); hx += 42; }
        const barX = hx + 15, barW = M.sx+M.sw-40 - barX;
        const pct = Math.max(0, GAME.anesthesia/GAME.anesthesiaMax);
        const barC = pct > 0.5 ? COLORS.green : pct > 0.2 ? COLORS.gold : COLORS.red;
        drawRoundRect(barX, M.sy+14, barW, 28, 14, '#1A1A1A', null);
        if (barW*pct > 5) drawRoundRect(barX+3, M.sy+17, (barW-6)*pct, 22, 11, barC, null);
        drawText('ANESTHESIA', barX+14, M.sy+28, 14, '#999', 'left', null, 0, 'normal');
    } else {
        drawRoundRect(M.sx+M.sw/2-120, M.sy+12, 240, 36, 12, 'rgba(0,0,0,0.5)', null);
        drawText('OR SYSTEM STANDBY', M.sx+M.sw/2, M.sy+30, 18, COLORS.green, 'center');
    }

    // LIVE badge
    drawRoundRect(M.sx+M.sw-105, M.sy+M.orH-30, 90, 26, 13, 'rgba(0,0,0,0.5)', null);
    if (Math.floor(performance.now()/500)%2===0) { ctx.fillStyle='#FF1744'; ctx.beginPath(); ctx.arc(M.sx+M.sw-90, M.sy+M.orH-17, 6, 0, Math.PI*2); ctx.fill(); }
    drawText('LIVE', M.sx+M.sw-74, M.sy+M.orH-17, 14, '#FFF', 'left', null, 0, 'normal');

    ctx.restore();
}

function drawPatient(cx, y) {
    drawRoundRect(cx-140, y+6, 280, 22, 8, '#BDBDBD', '#999', 2);
    drawRect(cx-120, y+28, 14, 22, '#888');
    drawRect(cx+106, y+28, 14, 22, '#888');
    ctx.fillStyle = '#EAC086'; ctx.beginPath(); ctx.arc(cx-110, y+2, 16, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = '#00ACC1'; ctx.beginPath(); ctx.arc(cx-110, y-2, 17, Math.PI, 0); ctx.fill();
    let breath = Math.sin(performance.now()/500)*4;
    ctx.fillStyle = '#81D4FA'; ctx.strokeStyle = '#0288D1'; ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(cx-95, y+6); ctx.quadraticCurveTo(cx-30, y-28-breath, cx, y-12-breath);
    ctx.quadraticCurveTo(cx+60, y-22, cx+120, y+6); ctx.lineTo(cx-95, y+6);
    ctx.fill(); ctx.stroke();
}

function drawArm(sx2, sy2, tx, ty, erratic, flip) {
    let dx = tx-sx2, dy = ty-sy2, bd = flip ? -1 : 1;
    let ex = sx2+dx*0.35+bd*50, ey = sy2+dy*0.5;
    let wx = sx2+dx*0.7+bd*18, wy = sy2+dy*0.85;
    if (erratic) { ex+=(Math.random()-0.5)*30; ey+=(Math.random()-0.5)*30; wx+=(Math.random()-0.5)*18; wy+=(Math.random()-0.5)*18; tx+=(Math.random()-0.5)*14; ty+=(Math.random()-0.5)*14; }
    ctx.lineWidth=14; ctx.strokeStyle = erratic ? '#FF4444' : '#546E7A';
    ctx.beginPath(); ctx.moveTo(sx2, sy2); ctx.lineTo(ex, ey); ctx.stroke();
    ctx.lineWidth=10; ctx.strokeStyle='#78909C'; ctx.beginPath(); ctx.moveTo(ex, ey); ctx.lineTo(wx, wy); ctx.stroke();
    ctx.lineWidth=7; ctx.strokeStyle='#90A4AE'; ctx.beginPath(); ctx.moveTo(wx, wy); ctx.lineTo(tx, ty); ctx.stroke();
    ctx.fillStyle='#263238'; ctx.beginPath(); ctx.arc(sx2, sy2, 14, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle='#37474F'; ctx.beginPath(); ctx.arc(ex, ey, 10, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = erratic ? '#FF1744' : '#00E676'; ctx.beginPath(); ctx.arc(ex, ey, 4, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle='#546E7A'; ctx.beginPath(); ctx.arc(wx, wy, 7, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle='#E0E0E0'; ctx.strokeStyle='#B0BEC5'; ctx.lineWidth=2;
    if (flip) { ctx.beginPath(); ctx.moveTo(tx-3,ty); ctx.lineTo(tx+1,ty+20); ctx.lineTo(tx+5,ty); ctx.closePath(); ctx.fill(); ctx.stroke(); }
    else { ctx.beginPath(); ctx.moveTo(tx,ty); ctx.lineTo(tx-5,ty+16); ctx.moveTo(tx,ty); ctx.lineTo(tx+5,ty+16); ctx.stroke(); }
}

