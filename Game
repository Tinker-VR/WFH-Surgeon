function drawNotifications(dt) {
    let active = [];
    for (let i = GAME.notifications.length-1; i >= 0; i--) {
        GAME.notifications[i].timer -= dt;
        if (GAME.notifications[i].timer <= 0) GAME.notifications.splice(i, 1);
        else active.unshift(GAME.notifications[i]);
    }
    const M = MONITOR;
    active.forEach((n, i) => {
        const alpha = Math.min(1, n.timer/300);
        const slideIn = Math.min(1, (n.maxTimer - n.timer)/200);
        const nx = M.sx + M.sw/2, ny = M.sy+55+i*38;
        const ox = (1-slideIn)*120;
        ctx.globalAlpha = alpha;
        drawRoundRect(nx-160+ox, ny-16, 320, 36, 18, 'rgba(0,0,0,0.75)', null);
        drawText(`${n.icon} ${n.text}`, nx+ox, ny+2, 17, '#FFF', 'center');
        ctx.globalAlpha = 1;
    });
}

